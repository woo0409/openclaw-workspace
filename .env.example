# ==================== 俄罗斯纽扣供应商数据库 - 后端环境变量配置 ====================
# 此文件用于docker-compose.yml
# 请复制为 .env 并填写实际值

# ==================== Tavily API 配置 ====================
# Tavily 搜索 API 密钥
# 获取地址: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ==================== API 认证配置 ====================
# API Key 用于保护写操作（POST/PUT/DELETE）
# 生成方法: openssl rand -hex 32
API_KEY=your_api_key_here

# ==================== 应用配置 ====================
# 调试模式（生产环境设为 false）
DEBUG=false

# 时区
TZ=Asia/Shanghai
